/* pages/lesson/lesson.wxss */
.container {
  padding: 0;
  min-height: 100vh;
  background: #F5F7FA;
}

/* 操作栏 */
.header-actions {
  display: flex;
  justify-content: flex-end;
  padding: 20rpx 40rpx;
  background: #fff;
  border-bottom: 1rpx solid #F0F0F0;
}

.action-btn {
  background: #F5F7FA;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #666;
}

.action-btn.active {
  background: #FFE8E8;
  color: #FF6B6B;
}

/* 标题 */
.lesson-title {
  padding: 40rpx 40rpx 20rpx;
  font-size: 40rpx;
  font-weight: bold;
  color: #2C3E50;
  background: #fff;
  margin-bottom: 20rpx;
}

/* 通用 section */
.section {
  background: #fff;
  padding: 30rpx 40rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 24rpx;
}

/* 内容文字 */
.content-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
}

/* 代码区域 */
.code-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.copy-btn {
  background: #4A90E2;
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.code-block {
  background: #2D2D2D;
  color: #F8F8F2;
  border-radius: 12rpx;
  padding: 24rpx;
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  line-height: 1.8;
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 提示文字 */
.hint-text {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

/* 题目卡片 */
.question-card {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #E8E8E8;
}

.question-number {
  font-size: 28rpx;
  font-weight: 600;
  color: #4A90E2;
  margin-bottom: 10rpx;
  display: inline-block;
  margin-right: 12rpx;
}

.question-type-tag {
  display: inline-block;
  background: #E8F4FD;
  color: #4A90E2;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.question-type-tag.fill {
  background: #FFF3CD;
  color: #FF9500;
}

.question-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

/* 选项 */
.options {
  margin-bottom: 20rpx;
}

.option-item {
  background: #fff;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  transition: all 0.2s;
}

.option-item:active {
  background: #F0F0F0;
}

.option-item.selected {
  border-color: #4A90E2;
  background: #E8F4FD;
}

.option-letter {
  width: 50rpx;
  height: 50rpx;
  background: #E8E8E8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-letter {
  background: #4A90E2;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 填空题输入 */
.fill-input-wrap {
  margin-bottom: 20rpx;
}

.fill-input-wrap .input {
  background: #fff;
  border: 2rpx solid #E8E8E8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

/* 显示/隐藏答案 */
.answer-toggle {
  text-align: center;
  padding: 20rpx;
  color: #4A90E2;
  font-size: 26rpx;
  background: #E8F4FD;
  border-radius: 12rpx;
  margin-top: 10rpx;
}

.answer-toggle:active {
  background: #D0E8F7;
}

/* 答案区域 */
.answer-section {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border-left: 6rpx solid #28A745;
}

.answer-label,
.explanation-label {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.answer-label {
  color: #28A745;
}

.explanation-label {
  color: #FF9500;
  margin-top: 20rpx;
}

.answer-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  padding-left: 10rpx;
}

.explanation-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  padding-left: 10rpx;
}

/* 空文字 */
.empty-text {
  text-align: center;
  padding: 40rpx 0;
  color: #999;
  font-size: 26rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* pages/admin-edit/admin-edit.wxss */
.container {
  padding: 0;
  min-height: 100vh;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* 表单容器 */
.form-container {
  padding: 30rpx 40rpx;
}

.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-item {
  margin-bottom: 30rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-row .label {
  margin-bottom: 0;
}

.help-btn {
  font-size: 24rpx;
  color: #4A90E2;
  background: #E8F4FD;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.input {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
}

.textarea {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 180rpx;
  line-height: 1.6;
}

.textarea.code {
  font-family: 'Courier New', monospace;
  background: #2D2D2D;
  color: #F8F8F2;
  min-height: 240rpx;
}

.save-btn {
  margin-top: 20rpx;
}

/* 知识点列表样式 */
.lessonlist-container {
  padding: 30rpx 40rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.add-btn {
  background: #4A90E2;
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
}

.lesson-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.lesson-info {
  margin-bottom: 20rpx;
}

.lesson-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.lesson-meta {
  font-size: 24rpx;
  color: #999;
}

.lesson-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 14rpx 24rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  flex: 1;
  text-align: center;
}

.action-btn.green {
  background: #D4EDDA;
  color: #28A745;
}

.action-btn.red {
  background: #F8D7DA;
  color: #DC3545;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 30rpx;
}

.empty-state .icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
  color: #999;
}

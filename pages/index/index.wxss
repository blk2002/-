/* pages/index/index.wxss */
.container {
  padding: 0;
}

/* 欢迎区域 */
.hero-section {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  padding: 60rpx 40rpx 80rpx;
  color: #fff;
}

.hello {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 课程区域 */
.section-title {
  padding: 40rpx 40rpx 20rpx;
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
}

.courses {
  padding: 0 40rpx;
}

.course-card {
  border-radius: 20rpx;
  padding: 50rpx 40rpx;
  margin-bottom: 30rpx;
  position: relative;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 226, 0.3);
  transition: transform 0.2s;
}

.course-card:active {
  transform: scale(0.98);
}

.course-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.course-name {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.course-desc {
  font-size: 26rpx;
  opacity: 0.9;
}

.course-arrow {
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 60rpx;
  opacity: 0.6;
}

/* 提示区域 */
.tip-section {
  padding: 20rpx 40rpx 40rpx;
}

.tip-card {
  background: #FFF9E6;
  border-radius: 16rpx;
  padding: 30rpx;
  display: flex;
  align-items: flex-start;
}

.tip-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FF9500;
  margin-bottom: 8rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #999;
  line-height: 1.6;
}

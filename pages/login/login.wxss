/* pages/login/login.wxss */
.login-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #4A90E2 0%, #357ABD 50%, #F5F7FA 50%);
  padding: 0;
  box-sizing: border-box;
}

/* Logo区域 */
.logo-area {
  padding: 120rpx 0 80rpx;
  text-align: center;
}

.logo-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.logo-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
}

.logo-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 表单卡片 */
.form-card {
  margin: 0 40rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

/* Tab切换 */
.form-tabs {
  display: flex;
  margin-bottom: 40rpx;
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 8rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #999;
  border-radius: 10rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #fff;
  color: #4A90E2;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* 输入区域 */
.form-content {
  padding-top: 10rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.input {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  border: 2rpx solid transparent;
}

.input:focus {
  border-color: #4A90E2;
  background: #fff;
}

/* 提交按钮 */
.submit-btn {
  margin-top: 40rpx;
  width: 100%;
}

/* 提示文字 */
.hint-text {
  margin-top: 30rpx;
  text-align: center;
  font-size: 24rpx;
  color: #FF9500;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 80rpx 0 40rpx;
  font-size: 24rpx;
  color: #999;
}

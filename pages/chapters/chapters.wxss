/* pages/chapters/chapters.wxss */
.container {
  padding: 0;
  min-height: 100vh;
}

/* 课程头部 */
.course-header {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  padding: 50rpx 40rpx;
  color: #fff;
}

.course-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.course-subtitle {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 章节列表 */
.chapter-list {
  padding: 30rpx 40rpx;
}

.chapter-item {
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.chapter-header {
  padding: 30rpx;
  display: flex;
  align-items: center;
}

.chapter-number {
  background: #4A90E2;
  color: #fff;
  padding: 10rpx 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.chapter-info {
  flex: 1;
}

.chapter-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.chapter-meta {
  font-size: 24rpx;
  color: #999;
}

.chapter-badge {
  font-size: 36rpx;
}

/* 知识点列表 */
.lesson-list {
  border-top: 1rpx solid #F0F0F0;
  padding: 10rpx 0;
}

.lesson-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #F8F8F8;
  transition: background 0.2s;
}

.lesson-item:last-child {
  border-bottom: none;
}

.lesson-item:active {
  background: #F5F7FA;
}

.lesson-item.active {
  background: #E8F4FD;
}

.lesson-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.lesson-content {
  flex: 1;
}

.lesson-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 6rpx;
}

.lesson-subtitle {
  font-size: 24rpx;
  color: #999;
  line-height: 1.4;
}

.lesson-arrow {
  font-size: 36rpx;
  color: #CCC;
  margin-left: 10rpx;
}

.empty-lesson {
  padding: 30rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

/* app.wxss - 全局样式 */

page {
  background-color: #F5F7FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #333;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  padding: 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 主按钮 */
.btn-primary {
  background: linear-gradient(135deg, #4A90E2 0%, #357ABD 100%);
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #fff;
  color: #4A90E2;
  border: 2rpx solid #4A90E2;
  border-radius: 12rpx;
  padding: 22rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

.btn-danger {
  background: #FF6B6B;
  color: #fff;
  border-radius: 12rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  text-align: center;
}

.btn-danger::after {
  border: none;
}

/* 标题 */
.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2C3E50;
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 20rpx;
}

/* 输入框 */
.input {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid transparent;
}

.input:focus {
  border-color: #4A90E2;
  background: #fff;
}

/* 文本区域 */
.textarea {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  font-size: 28rpx;
  width: 100%;
  box-sizing: border-box;
  min-height: 160rpx;
}

/* 标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: #E8F4FD;
  color: #4A90E2;
  margin-right: 12rpx;
}

.tag-success {
  background: #D4EDDA;
  color: #28A745;
}

.tag-warning {
  background: #FFF3CD;
  color: #FFC107;
}

.tag-danger {
  background: #F8D7DA;
  color: #DC3545;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 30rpx;
  color: #999;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.empty-state .text {
  font-size: 28rpx;
}

/* 列表项 */
.list-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.list-item:active {
  background: #F5F7FA;
}

/* 代码块 */
.code-block {
  background: #2D2D2D;
  color: #F8F8F2;
  border-radius: 12rpx;
  padding: 24rpx;
  font-family: 'Courier New', monospace;
  font-size: 24rpx;
  line-height: 1.8;
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-all;
}

.code-keyword {
  color: #FF79C6;
}

.code-string {
  color: #F1FA8C;
}

.code-comment {
  color: #6272A4;
}

.code-number {
  color: #BD93F9;
}

/* 加载中 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 底部间距 */
.bottom-space {
  height: 60rpx;
}

/* 行布局 */
.row {
  display: flex;
  align-items: center;
}

.row-space {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 进度条 */
.progress-bar {
  width: 100%;
  height: 12rpx;
  background: #E8E8E8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4A90E2, #67B8F5);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: #E8E8E8;
  margin: 20rpx 0;
}

/* 选项卡片 */
.option-item {
  background: #F5F7FA;
  border-radius: 12rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.option-item.selected {
  background: #E8F4FD;
  border-color: #4A90E2;
}

.option-item.correct {
  background: #D4EDDA;
  border-color: #28A745;
}

.option-item.wrong {
  background: #F8D7DA;
  border-color: #DC3545;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 60rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4A90E2, #357ABD);
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 226, 0.4);
  z-index: 999;
}
